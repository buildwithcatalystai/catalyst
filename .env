# Catalyst plugin configuration — committed defaults.
# These values point at the public Catalyst deployment; no setup needed.
# To override locally, set the same vars in your shell env before launching
# Claude Code (e.g. `export CATALYST_BACKEND_URL=http://localhost:8000`).

# URL where catalyst-mcp accepts MCP requests (port 9000 by default).
CATALYST_MCP_URL=http://13.202.117.250:9000/mcp

# URL where the catalyst-builder wizard backend lives. The PostToolUse
# hook POSTs translated tool-call events to {CATALYST_BACKEND_URL}/api/
# sessions/{id}/turn so they show up live in ChatPane and persist to the
# PostgresSaver checkpoint.
CATALYST_BACKEND_URL=http://13.202.117.250:8000

# Shared secret for the /turn endpoint's X-Catalyst-Mcp-Secret header.
# Matches CATALYST_MCP_SECRET in the wizard backend's own .env.
CATALYST_MCP_SECRET=42rF9Bip2iAmHGEyfA0l0l9cDtTHtAZoln5JKwyDXPc
