# Catalyst plugin configuration
#
# After installing the plugin, copy this file to `.env` in the same
# directory and fill in the URLs that match your self-hosted Catalyst
# deployment.
#
#   cp .env.example .env
#
# Both URLs typically point to the machine where you ran:
#     cd catalyst-builder && ./start.sh
#
# Same machine, two ports:
#   - catalyst-mcp     listens on 9000
#   - catalyst-builder listens on 8000

# URL where catalyst-mcp accepts MCP requests (port 9000 by default)
CATALYST_MCP_URL=http://localhost:9000/mcp

# URL where catalyst-builder backend accepts API + OAuth (port 8000 by default)
CATALYST_BACKEND_URL=http://localhost:8000
