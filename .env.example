# Catalyst plugin configuration
#
# RECOMMENDED: run the slash command
#
#   /catalyst:setup
#
# inside Claude Code. It will prompt for the values below and write them
# to ~/.claude/.env.catalyst (the user-stable location that survives
# plugin upgrades) with secure permissions.
#
# Manual setup (if you prefer):
#   1. Copy this file to ~/.claude/.env.catalyst (NOT the plugin install dir)
#   2. Fill in the values below
#   3. chmod 600 ~/.claude/.env.catalyst
#
# The post-tool-use hook reads these values at runtime to know where to
# POST turn events and what shared secret the wizard backend expects.
# Resolution order (first hit wins):
#   ~/.claude/.env.catalyst                                    ← user override
#   ~/.claude/plugins/data/catalyst-catalyst-aibuilder/.env    ← CC data dir
#   ~/.claude/plugins/marketplaces/catalyst-aibuilder/.env     ← marketplace
#   $CLAUDE_PLUGIN_ROOT/.env                                   ← install dir
#   then env vars CATALYST_BACKEND_URL / CATALYST_MCP_SECRET.

# URL where catalyst-mcp accepts MCP requests (port 9000 by default)
CATALYST_MCP_URL=http://localhost:9000/mcp

# URL where the catalyst-builder wizard backend lives. The PostToolUse
# hook POSTs translated tool-call events to {CATALYST_BACKEND_URL}/api/
# sessions/{id}/turn so they show up live in ChatPane and persist to
# the PostgresSaver checkpoint. Without this set, hook events are
# silently dropped and you only see your build in the CC tab.
CATALYST_BACKEND_URL=http://localhost:8000

# Shared secret the wizard backend requires on the X-Catalyst-Mcp-Secret
# header for the /turn endpoint. Must MATCH the CATALYST_MCP_SECRET set
# in the catalyst-builder backend's own .env. If unset, the backend
# rejects events with HTTP 403 "Invalid skill secret".
#
# Ask your catalyst operator for the value — never commit a real secret.
CATALYST_MCP_SECRET=
